{
  "name": "@velocity-bpa/n8n-nodes-cin7-core",
  "version": "1.0.0",
  "description": "n8n community node for Cin7 Core (DEAR Systems) inventory management",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials --ext .ts",
    "lint:fix": "eslint nodes credentials --ext .ts --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "credentials": [
      "dist/credentials/Cin7CoreApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Cin7Core/Cin7Core.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "keywords": [
    "n8n",
    "cin7",
    "dear",
    "inventory",
    "erp"
  ]
}